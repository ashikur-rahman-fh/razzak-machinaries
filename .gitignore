# env files
**/.env
**/.env.*
!**/.env.example

# generated nginx vhost config (source: conf.d/default.conf.template + infra/env/prod/.env)
infra/nginx/prod/conf.d/default.conf

# production certificates
infra/nginx/prod/certs/*
!infra/nginx/prod/certs/.gitkeep
!infra/nginx/prod/certs/README.md

# certificate file types
*.key
*.crt
*.pem

# Python
__pycache__/
*.pyc
# Root symlink for editor discovery (created by make editor-happy)
/.venv
.venv/
apps/backend/.venv/
.pytest_cache/

# Node
node_modules/
.pnpm-store/
.next/
dist/
coverage/

# TypeScript / Next.js generated (do not commit)
*.tsbuildinfo
next-env.d.ts

# OS / logs
.DS_Store
*.log

# Django collected static files (keep directory; contents generated)
apps/backend/staticfiles/*
!apps/backend/staticfiles/.gitkeep

# Django user uploads (profile pictures, capture sessions, etc.)
apps/backend/media/*
!apps/backend/media/.gitkeep

# database backups
infra/scripts/db/backups/*.sql
infra/scripts/db/backups/*.sql.gz
