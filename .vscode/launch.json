{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Django Backend Docker",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/apps/backend",
          "remoteRoot": "/app"
        }
      ],
      "django": true,
      "justMyCode": true
    }
  ]
}
