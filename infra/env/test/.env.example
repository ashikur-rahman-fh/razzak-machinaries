PROJECT_NAME=razzak-machinaries
ENVIRONMENT=test
DEBUG=false
SECRET_KEY=test-not-for-production
DJANGO_SETTINGS_MODULE=config.settings.test
ALLOWED_HOSTS=localhost,127.0.0.1,backend,backend-test
CSRF_TRUSTED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

POSTGRES_DB=razzak_machinaries_test
POSTGRES_USER=razzak_machinaries
POSTGRES_PASSWORD=razzak_machinaries_test_password
POSTGRES_HOST=postgres-test
POSTGRES_PORT=5432

REDIS_URL=redis://redis-test:6379/0

BACKEND_URL=http://backend-test:8000
NEXT_PUBLIC_BACKEND_MAIN_API_URL=http://backend-test:8000
NEXT_PUBLIC_THEME_MODE=system

MAIN_FRONTEND_HOST=localhost:3000
ADMIN_FRONTEND_HOST=localhost:3001
API_HOST=backend-test:8000

# Security — test settings use high throttle limits and axes failure limit 999 by default.

WAIT_FOR_DEBUGGER=false

# Admin superusers (JSON array). Idempotent sync: make test-sync-superusers
# ADMIN_SUPERUSERS='[{"username":"admin","email":"admin@example.com","password":"change-me-in-env","first_name":"Admin","last_name":"User"}]'
# ADMIN_SUPERUSER_UPDATE_PASSWORD=false
