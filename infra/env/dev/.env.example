PROJECT_NAME=razzak-machinaries
ENVIRONMENT=dev
DEBUG=true
SECRET_KEY=change-me-dev-secret-key
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:8000,http://127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:8000,http://127.0.0.1:8080

POSTGRES_DB=razzak_machinaries_dev
POSTGRES_USER=razzak_machinaries
POSTGRES_PASSWORD=razzak_machinaries_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

BACKEND_URL=http://localhost:8000
# Browser API URL when using dev Nginx on :8080 (recommended). Use :8000 only if you
# hit the Next apps directly on :3000/:3001 and backend is reachable on the host.
NEXT_PUBLIC_BACKEND_MAIN_API_URL=http://localhost:8080

# Optional Next.js basePath for the admin app (path-based routing). Leave empty in dev:
# admin runs at http://localhost:3001/ on its own port. Production typically uses
# separate hostnames with this empty.
NEXT_PUBLIC_BASE_PATH=
# Theme mode for both frontend-main and frontend-admin: light | dark | system.
# Empty, missing, or invalid values safely fall back to system behavior.
NEXT_PUBLIC_THEME_MODE=system

MAIN_FRONTEND_HOST=localhost:3000
ADMIN_FRONTEND_HOST=localhost:3001
API_HOST=localhost:8000

# Security (optional overrides — defaults are in Django settings)
# DRF_THROTTLE_ANON=100/hour
# DRF_THROTTLE_API=200/hour
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_MINUTES=30
# DATA_UPLOAD_MAX_BYTES=2621440
# CLIENT_MAX_BODY_SIZE=25m
# CSP_REPORT_ONLY=false

# Translation (Azure Translator)
TRANSLATION_PROVIDER=azure
AZURE_TRANSLATOR_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
# AZURE_TRANSLATOR_REGION=your-azure-region
# AZURE_TRANSLATOR_KEY=set-in-local-.env-or-secrets-manager-never-commit
# TRANSLATION_TIMEOUT_SECONDS=10
# TRANSLATION_CACHE_TTL_SECONDS=86400
# DRF_THROTTLE_ADMIN_TRANSLATION=60/minute

WAIT_FOR_DEBUGGER=false

# Admin superusers (JSON array). Idempotent sync: make backend-sync-superusers
# ADMIN_SUPERUSERS='[{"username":"admin","email":"admin@example.com","password":"change-me-in-env","first_name":"Admin","last_name":"User"}]'
# ADMIN_SUPERUSER_UPDATE_PASSWORD=false
